generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
}

enum Sex {
  male
  female
}

enum FoodSource {
  custom
  openfoodfacts
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  email         String        @unique
  passwordHash  String        @map("password_hash")
  name          String?
  sex           Sex?
  age           Int?
  weightKg      Float?        @map("weight_kg")
  heightCm      Float?        @map("height_cm")
  activityLevel ActivityLevel @default(sedentary) @map("activity_level")
  dailyGoalKcal Int?          @map("daily_goal_kcal")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  mealLogs      MealLog[]
  createdFoods  Food[]

  @@map("users")
}

model Food {
  id              String     @id @default(uuid()) @db.Uuid
  name            String
  kcalPer100g     Float      @map("kcal_per_100g")
  proteinPer100g  Float      @map("protein_per_100g")
  fatPer100g      Float      @map("fat_per_100g")
  carbsPer100g    Float      @map("carbs_per_100g")
  source          FoodSource
  createdByUserId String?    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  createdByUser   User?      @relation(fields: [createdByUserId], references: [id])
  mealLogs        MealLog[]

  @@index([name])
  @@index([createdByUserId])
  @@map("foods")
}

model MealLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  foodId       String   @map("food_id") @db.Uuid
  quantityG    Float    @map("quantity_g")
  totalKcal    Float    @map("total_kcal")
  totalProtein Float    @map("total_protein")
  totalFat     Float    @map("total_fat")
  totalCarbs   Float    @map("total_carbs")
  mealType     MealType @map("meal_type")
  logDate      DateTime @map("log_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  food         Food     @relation(fields: [foodId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([logDate])
  @@index([userId, logDate])
  @@map("meal_logs")
}
